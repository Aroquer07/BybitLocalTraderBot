# =============================================================================
# BybitBot — Agente de Trading Autônomo e Híbrido
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# --- Telegram (Telethon) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION_NAME=bybit_bot_session
TELEGRAM_CHANNEL_ID=-1001234567890
# IDs de tópicos separados por vírgula (opcional — override/fallback quando nomes não resolvem)
# Fallback opcional se TELEGRAM_TOPIC_NAMES não resolver (ex: 4,47832,348126)
TELEGRAM_TOPIC_IDS=4,47832,348126
# Nomes de tópicos separados por vírgula (case-insensitive, match parcial/fuzzy)
TELEGRAM_TOPIC_NAMES=Call membros,calls top traders,Sinais vip do mack

# --- Bybit (CCXT V5) ---
# Modo de operação (escolha UM):
#   testnet = sandbox Bybit (api-testnet.bybit.com) — chaves do testnet.bybit.com
#   demo    = Demo Trading na mainnet (api-demo.bybit.com) — paper trading com preços reais
#   live    = conta real com dinheiro (api.bybit.com)
#
# Legado: BYBIT_TESTNET=true/false ainda funciona se BYBIT_MODE não estiver definido
BYBIT_MODE=testnet

# Credenciais Testnet (obrigatórias quando BYBIT_MODE=testnet)
BYBIT_TESTNET_API_KEY=your_bybit_testnet_api_key
BYBIT_TESTNET_API_SECRET=your_bybit_testnet_api_secret

# Credenciais Demo Trading (obrigatórias quando BYBIT_MODE=demo)
# Gere em: Bybit mainnet → alternar para "Demo Trading" → API Management
BYBIT_DEMO_API_KEY=your_bybit_demo_api_key
BYBIT_DEMO_API_SECRET=your_bybit_demo_api_secret

# Credenciais Live / conta real (obrigatórias quando BYBIT_MODE=live)
BYBIT_API_KEY=your_bybit_live_api_key
BYBIT_API_SECRET=your_bybit_live_api_secret

BYBIT_DEFAULT_LEVERAGE=15
BYBIT_MAX_LEVERAGE=30
# Apenas perpetual linear (futures) — sem spot
BYBIT_MARKET_TYPE=linear_swap

# --- Ollama (LLM local) ---
OLLAMA_HOST=http://localhost:11434
# qwen3:8b recomendado para GPUs ~12GB VRAM; thinking desligado no llm_client
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=24h

# --- Regras de negócio ---
MIN_CONFIDENCE_THRESHOLD=0.90
DEFAULT_TIMEFRAME=15m
TIMEFRAMES=5m,15m,30m
OHLCV_LIMIT=200
# Estilos permitidos: daytrade, scalp (comma-separated)
ALLOWED_TRADE_STYLES=daytrade,scalp
# Rejeitar swing e spot explicitamente
REJECT_TRADE_STYLES=swing,spot

# --- Gestão de risco ---
RISK_PER_TRADE_PCT=3.0
MAX_POSITION_PCT=5.0
TP1_CLOSE_PCT=25
TP2_CLOSE_PCT=25
TP3_CLOSE_PCT=25
TP4_CLOSE_PCT=25
MOVE_SL_TO_ENTRY_ON_TP2=true

# --- Runtime config (hot-reload) ---
SETTINGS_PATH=data/settings.json

# --- ngrok (dashboard remoto) ---
# Token em https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_TOKEN=
# false para desligar tunel mesmo com token configurado
NGROK_ENABLED=true
# false = tunel sem login Google (apenas URL publica)
NGROK_OAUTH=false
